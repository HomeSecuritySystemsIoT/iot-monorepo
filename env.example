# ── Server ────────────────────────────────────────────────────────────────────
# Domain name pointing to this server — docker-compose derives all public URLs from this:
#   NEXT_PUBLIC_FRONTEND_URL  → https://$SERVER_HOST       (baked into JS bundle)
#   NEXT_PUBLIC_BACKEND_WS_URL → wss://$SERVER_HOST/backend (baked into JS bundle)
SERVER_HOST=iot-project.ethan-rouimi.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=homesecurity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433

# ── Auth ──────────────────────────────────────────────────────────────────────
# Keep true — the app is served over HTTPS via Caddy
SECURE_COOKIES=true
# Email address that gets admin-level access in the dashboard
ADMIN_EMAIL=your@email.com
# Shared secret between backend-iot and frontend (device registration check)
BACKEND_API_SECRET=change-me-in-production
