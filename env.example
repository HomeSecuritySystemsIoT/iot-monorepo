# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=homesecurity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Public URL of this server — used in QR codes and baked into the JS bundle
NEXT_PUBLIC_FRONTEND_URL=http://YOUR_SERVER_IP:3000
# WebSocket URL of the stream server — used by the browser to connect to camera feeds
NEXT_PUBLIC_BACKEND_WS_URL=ws://YOUR_SERVER_IP:7890
# Email address that gets admin-level access
ADMIN_EMAIL=your@email.com

# ── Backend ↔ Frontend auth ───────────────────────────────────────────────────
# Shared secret: backend uses it to query /api/iot/devices/:id on the frontend
BACKEND_API_SECRET=change-me-in-production
