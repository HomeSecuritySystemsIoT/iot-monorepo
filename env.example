# ── Server ────────────────────────────────────────────────────────────────────
# IP or domain of this server — docker-compose derives all public URLs from this:
#   NEXT_PUBLIC_FRONTEND_URL  → http://$SERVER_HOST:3000  (baked into JS bundle)
#   NEXT_PUBLIC_BACKEND_WS_URL → ws://$SERVER_HOST:7890   (baked into JS bundle)
SERVER_HOST=YOUR_SERVER_IP

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=homesecurity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433

# ── Auth ──────────────────────────────────────────────────────────────────────
# Email address that gets admin-level access in the dashboard
ADMIN_EMAIL=your@email.com
# Shared secret between backend-iot and frontend (device registration check)
BACKEND_API_SECRET=change-me-in-production
